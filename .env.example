# Set these in your deployment platform's secret manager; do not commit .env.
DATABASE_URL=postgresql://pulsenet:change-me@127.0.0.1:5432/pulsenet
JWT_SECRET=replace-with-a-long-random-secret
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Comma-separated HTTPS origins, e.g. https://portal.example.co.ke,https://admin.example.co.ke
# Include the Hotspot captive DNS name too (it's served over plain HTTP by
# RouterOS, e.g. http://login.pulsenet.test) or mikrotik-hotspot/hotspot/login.html's
# package-grid fetch() calls will be blocked by CORS.
CORS_ORIGINS=https://portal.example.co.ke,https://admin.example.co.ke,http://login.pulsenet.test
# M-PESA/Daraja and OTP gateway credentials belong in the deployment secret store.
# Do not enable customer login or mark an STK payment complete without verified callbacks.

# First-run seed (supply the password through the deployment secret store only).
SEED_ADMIN_EMAIL=enoswebala27@gmail.com
SEED_ADMIN_PASSWORD=
SEED_CUSTOMER_PHONE=0743901680
